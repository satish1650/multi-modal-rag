PARSER_BACKEND=cloud          # "cloud" (Z.AI MaaS) | "ollama" (local Ollama)
Z_AI_API_KEY=your-z-ai-api-key-here
LOG_LEVEL=INFO
OUTPUT_DIR=./output

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o

# Embedding provider
EMBEDDING_PROVIDER=openai        # "openai" | "gemini"
EMBEDDING_MODEL=text-embedding-3-large
# text-embedding-3-small: set EMBEDDING_MODEL=text-embedding-3-small, EMBEDDING_DIMENSIONS=1536
EMBEDDING_DIMENSIONS=3072
# ⚠ Changing EMBEDDING_DIMENSIONS after collection creation requires --overwrite

# Gemini (only needed if EMBEDDING_PROVIDER=gemini)
GEMINI_API_KEY=                  # AIzaSy...

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documents

# Reranker
RERANKER_BACKEND=openai       # "jina" | "openai" | "bge" | "qwen"
RERANKER_TOP_N=5
JINA_API_KEY=                  # only needed if RERANKER_BACKEND=jina

# Feature flags
IMAGE_CAPTION_ENABLED=true

# API server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Logging
LOG_JSON=false   # true = JSON lines for log aggregators
